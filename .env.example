# PostgreSQL (локально: Docker или managed)
DATABASE_URL="postgresql://done48:done48@localhost:5432/done48?schema=public"

# Публичный URL сайта (канонический домен). Нужен для SEO: sitemap, Open Graph, JSON-LD.
# В проде: https://ваш-домен.ru — совпадайте с тем, что в браузере (с www или без).
# NEXT_PUBLIC_SITE_URL="https://done48.ru"

# NextAuth (этап 4)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# После первого деплоя схемы: npm run db:push && npm run db:seed
# Сид: категории + admin@demo.local / demo12345

# E2E (npm run test:e2e): после seed поднимется dev-сервер на :3000, если он ещё не запущен.
# Один раз: npx playwright install chromium

# Интеграционные тесты (npm run test):
# 1) cp .env.test.example .env.test
# 2) npm run test:db:up && npm run test:db:migrate   — локальный Postgres на :5433 (нужен Docker Desktop)
#    Без Docker: test:db:up сообщит, что установить; test:db:migrate и npm test завершатся без P1001 (интеграции skip).
#    CI с обязательной БД: REQUIRE_TEST_DB=1 npm run test:db:migrate
# 3) npm test
# В .env.test задайте TEST_DATABASE_URL — он подставится вместо DATABASE_URL на время Vitest.
# TEST_DATABASE_URL="postgresql://done48:done48@127.0.0.1:5433/done48_test?schema=public"

# Почта для «Забыли пароль» — сервис Resend (https://resend.com): API Keys → создать ключ.
# Без RESEND_API_KEY в development ссылка сброса пишется в консоль Node (терминал, где запущен next dev).
# EMAIL_FROM — опционально; по умолчанию в коде: DONE48 <info@done48.ru> (домен должен быть подтверждён в Resend).
# NEXTAUTH_URL должен совпадать с URL сайта, иначе в письме будет неверная ссылка.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM="DONE48 <info@done48.ru>"

# Опционально: S3-совместимое хранилище вложений (этап загрузки файлов)
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
