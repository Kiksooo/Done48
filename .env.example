# PostgreSQL (локально: Docker или managed)
DATABASE_URL="postgresql://done48:done48@localhost:5432/done48?schema=public"

# NextAuth (этап 4)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# После первого деплоя схемы: npm run db:push && npm run db:seed
# Сид: категории + admin@demo.local / demo12345

# E2E (npm run test:e2e): после seed поднимется dev-сервер на :3000, если он ещё не запущен.
# Один раз: npx playwright install chromium

# Интеграционные тесты (npm run test): Vitest подхватывает DATABASE_URL из .env / .env.local.
# Можно задать отдельную БД (переопределит URL при прогоне):
# TEST_DATABASE_URL="postgresql://done48:done48@localhost:5432/done48_test?schema=public"

# Опционально: письма «сброс пароля» через Resend (https://resend.com). Без ключей в dev ссылка пишется в консоль сервера.
# RESEND_API_KEY=
# EMAIL_FROM="DONE48 <onboarding@resend.dev>"

# Опционально: S3-совместимое хранилище вложений (этап загрузки файлов)
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
