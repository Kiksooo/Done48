# PostgreSQL
# Не храните в .env на машине разработчика URL продакшен-БД — используйте отдельный инстанс (dev/stage)
# и другой файл/секреты для деплоя. Локально: Docker или managed Postgres только для разработки.
DATABASE_URL="postgresql://done48:done48@localhost:5432/done48?schema=public"

# Опционально: отдельные URL для других окружений (в CI/хостинге задаются секретами, не коммитьте прод).
# DATABASE_URL_STAGING=
# DATABASE_URL_PROD=  # только в секретах пайплайна, не в репозитории

# Публичный URL сайта (канонический домен). Нужен для SEO: sitemap, Open Graph, JSON-LD.
# В проде: https://ваш-домен.ru — совпадайте с тем, что в браузере (с www или без).
# NEXT_PUBLIC_SITE_URL="https://done48.ru"

# Аналитика (опционально)
# Google Analytics 4 — измерение вида G-XXXXXXXXXX (включается в layout при наличии).
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Яндекс.Метрика: числовой id счётчика. По умолчанию в коде — существующий счётчик; отключить: 0 или false
# NEXT_PUBLIC_YANDEX_METRIKA_ID=108289111

# Мониторинг ошибок (подключение SDK в коде — отдельно; типично SENTRY_DSN + @sentry/nextjs).
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# NextAuth (этап 4)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Первая настройка схемы локально: npx prisma migrate dev (или migrate deploy на пустой БД), затем npm run db:seed.
# В CI/проде перед деплоем: бэкап БД (по политике хостинга) и npx prisma migrate deploy — не полагаться только на db push.
# Сид: категории + admin@demo.local / demo12345

# E2E (npm run test:e2e): после seed поднимется dev-сервер на :3000, если он ещё не запущен.
# Один раз: npx playwright install chromium
# Против уже задеплоенного staging: PLAYWRIGHT_BASE_URL=https://staging.example.com npm run test:e2e:smoke
# Либо GitHub Actions → workflow «E2E staging smoke» (ввод base_url при запуске).

# Интеграционные тесты (npm run test):
# 1) cp .env.test.example .env.test
# 2) npm run test:db:up && npm run test:db:migrate   — локальный Postgres на :5433 (нужен Docker Desktop)
#    Без Docker: test:db:up сообщит, что установить; test:db:migrate и npm test завершатся без P1001 (интеграции skip).
#    Строгий migrate: REQUIRE_TEST_DB=1 npm run test:db:migrate
#    Строгие интеграции в тестах: REQUIRE_TEST_DB=1 npm test (в GitHub Actions CI включено по умолчанию)
# 3) npm test
# В .env.test задайте TEST_DATABASE_URL — он подставится вместо DATABASE_URL на время Vitest.
# TEST_DATABASE_URL="postgresql://done48:done48@127.0.0.1:5433/done48_test?schema=public"

# Почта для «Забыли пароль» — Resend (https://resend.com):
# 1) Domains → добавить свой домен и пройти DNS (без этого API вернёт ошибку, письма не уйдут).
# 2) API Keys → создать ключ → RESEND_API_KEY.
# 3) EMAIL_FROM — адрес на этом домене, например: "DONE48 <noreply@ваш-домен.ru>".
# Без RESEND_API_KEY в development ссылка сброса пишется в консоль Node; в production письма не отправятся.
# NEXT_PUBLIC_SITE_URL (или NEXTAUTH_URL) — публичный https URL сайта; от него строится ссылка в письме.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM="DONE48 <noreply@ваш-домен.ru>"

# MailerLite: синхронизация opt-in из профиля (вкл/выкл рассылки) с аудиторией для email-кампаний.
# Integrations → MailerLite API → Generate new token. ID группы(п) — из аудитории MailerLite (несколько через запятую).
# Без MAILERLITE_API_KEY синхронизация не вызывается.
# MAILERLITE_API_KEY=
# MAILERLITE_GROUP_ID=

# S3-совместимое хранилище для загрузок (чат, аватар). Без этих переменных файлы пишутся в public/uploads локально.
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# Публичный URL префикса объектов (как открывается в браузере): виртуальный хост бакета, CDN или path-style до ключа.
# S3_PUBLIC_BASE_URL="https://ваш-бакет.s3.amazonaws.com"
# Регион (AWS / Yandex / Selectel по документации; MinIO часто игнорируется)
# S3_REGION="us-east-1"
# Кастомный endpoint: MinIO, Yandex Object Storage, Selectel API
# S3_ENDPOINT="https://storage.yandexcloud.net"
# Для MinIO и многих совместимых API: S3_FORCE_PATH_STYLE=true
# S3_FORCE_PATH_STYLE=

# Oplatum Merchant API — https://oplatum.com/api-docs
# OPLATUM_API_BASE_URL — только origin (https://…), без /merchant-api/…
# OPLATUM_API_BASE_URL=https://…
# Опционально другой префикс пути (по умолчанию merchant-api/v1):
# OPLATUM_MERCHANT_API_PREFIX=merchant-api/v1
# OPLATUM_API_KEY=ak_live_…
# OPLATUM_SECRET_KEY=sk_live_…  (подпись запросов: timestamp.nonce.METHOD.path.body → HMAC-SHA256 hex)
# OPLATUM_HMAC_SECRET=…  (если отдельный от sk)
# OPLATUM_SIGN_WITH_API_KEY=true  (только если так в доке)
# Вебхук: HMAC-SHA256(secret, "{timestamp}.{rawBody}") → hex; заголовки X-Webhook-Signature, X-Webhook-Timestamp
# OPLATUM_WEBHOOK_SECRET=…
# OPLATUM_WEBHOOK_SIGNATURE_HEADER=x-webhook-signature
# OPLATUM_WEBHOOK_TIMESTAMP_HEADER=x-webhook-timestamp
# URL вебхука: {NEXT_PUBLIC_SITE_URL}/api/webhooks/oplatum
# Подпись кнопки баланса (косметика): sbp | card | sbp,card
# OPLATUM_PAYMENT_METHOD_TYPES=sbp
# Допустимое отклонение времени вебхука, сек (по умолчанию 300):
# OPLATUM_WEBHOOK_TOLERANCE_SEC=300
# В проде при настроенном Oplatum демо-пополнение отключено; чтобы включить (только осознанно):
# ALLOW_DEMO_BALANCE_TOPUP=true
